---
// Layout.astro — the exact chrome from the pre-SEO app (header + bottom nav),
// with every navigation turned into a real link instead of a hash toggle.
// Appearance is byte-for-byte the original: same DOM classes, same CSS, same
// logo. Only the hrefs changed (hash -> real URLs) and the league dropdown
// items are now <a> links (native, JS-free), the pill toggled by a 6-line script.
import '../styles/global.css';
import { LEAGUES, SESSION_LEAGUES } from '../lib/leagues';
import GateModal from '../components/GateModal.astro';

export interface Props {
  title: string;
  description?: string;
  subLabel: string;          // header sub line (scope)
  pillLabel: string;         // header pill text (short league label)
  pageBase: string;          // url base for the 4 nav tabs, e.g. '/uaa/u15'
  activeTab: 'stats' | 'leaders' | 'compare' | 'teams' | null;
  canonical?: string;
  robots?: string;
  trackTitle?: string;       // human-readable name for analytics (player/team/matchup) — not SEO title
}
const { title, description = '', subLabel, pillLabel, pageBase, activeTab, canonical, robots, trackTitle } = Astro.props;

// Share-preview image: a real full-page screenshot of THIS page (api/og-shot.js)
// at phone width, so link previews show the whole content — Andy's pick over the
// old top-1200x630 crop and the drawn-card generator, both since removed.
// Self-referential — the function screenshots whatever host actually receives
// the request, so this works unchanged on any domain (preview or production).
const shotPath = new URL(canonical || Astro.url.pathname, Astro.site || Astro.url.origin).pathname;
const ogImage = `${(Astro.site?.href || Astro.url.origin).replace(/\/$/, '')}/api/og-shot?path=${encodeURIComponent(shotPath)}`;

// Bottom-nav destinations (real pages). Leaders defaults to the PPG board.
const tabs = [
  { v: 'stats', label: 'Stats', href: `${pageBase}/stats` },
  { v: 'leaders', label: 'Leaders', href: `${pageBase}/leaders/ppg` },
  { v: 'compare', label: 'Compare', href: `${pageBase}/compare` },
  { v: 'teams', label: 'Teams', href: `${pageBase}/teams` },
];
const navIcons: Record<string, string> = {
  stats: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>',
  leaders: '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>',
  compare: '<path d="M10 3H6a2 2 0 0 0-2 2v14c0 1.1.9 2 2 2h4M14 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4M12 8v8M9 11l3-3 3 3"/>',
  teams: '<path d="M12 2 3 7v5c0 5.25 3.75 10.15 9 11.25C17.25 22.15 21 17.25 21 12V7L12 2z"/>',
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  {canonical && <link rel="canonical" href={canonical} />}
  {robots && <meta name="robots" content={robots} />}
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Circuit Stats" />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="theme-color" content="#08090f" />
</head>
<body>
<GateModal />
<header class="hdr">
  <a class="hdr-home" id="hdr-home" href="/" data-track="header:logo">
    <div class="hdr-logo" id="hdr-logo" role="img" aria-label="Circuit Stats logo"></div>
    <div class="hdr-info">
      <div class="hdr-title" id="hdr-title">Circuit Stats</div>
      <div class="hdr-sub" id="hdr-sub">{subLabel}</div>
    </div>
  </a>
  <a class="hdr-contact" href="mailto:andyfazliu@gmail.com?subject=UAA U15 League Stats" data-track="header:contact" aria-label="Contact us">
    Questions?
  </a>
  <div class="hdr-pill" id="league-pill" onclick="toggleLeagueDropdown(event)" title="Switch mode" data-track="header:league-pill">
    <span id="league-pill-label">{pillLabel}</span><span class="hdr-pill-caret">▼</span>
    <div class="league-dropdown" id="league-dropdown">
      {SESSION_LEAGUES.map(sl => <a class="ld-item" href={`${sl.urlBase}/${activeTab === 'leaders' ? 'leaders/ppg' : activeTab === 'compare' ? 'compare' : activeTab === 'teams' ? 'teams' : 'stats'}`} data-track={`header:league-switch:${sl.key}`}>{sl.label.replace(' · Session ', ' S')}</a>)}
      {LEAGUES.map(l => <a class="ld-item" href={`${l.urlBase}/${activeTab === 'leaders' ? 'leaders/ppg' : activeTab === 'compare' ? 'compare' : activeTab === 'teams' ? 'teams' : 'stats'}`} data-track={`header:league-switch:${l.key}`}>{l.label}</a>)}
    </div>
  </div>
</header>

<main class="main">
  <slot />
</main>

<nav class="nav">
  {tabs.slice(0, 2).map(t => (
    <a class:list={["nav-btn", { active: t.v === activeTab }]} data-v={t.v} href={t.href} data-track={`nav:${t.v}`}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={navIcons[t.v]} />
      {t.label}
    </a>
  ))}
  <button class="nav-btn" id="share-btn" title="Share this page" aria-label="Share this page" data-track="header:share">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/>
    </svg>
    Share
  </button>
  {tabs.slice(2).map(t => (
    <a class:list={["nav-btn", { active: t.v === activeTab }]} data-v={t.v} href={t.href} data-track={`nav:${t.v}`}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" set:html={navIcons[t.v]} />
      {t.label}
    </a>
  ))}
</nav>

<script is:inline define:vars={{ trackTitleInit: trackTitle || null }}>
  // Explicit window assignment (not a bare function declaration): define:vars
  // makes Astro emit this script as a module, and modules don't leak top-level
  // function declarations onto window — the inline onclick="" attribute below
  // needs it there.
  window.toggleLeagueDropdown = function (e) {
    e.stopPropagation();
    document.getElementById('league-dropdown').classList.toggle('open');
  };
  document.addEventListener('click', function () {
    var dd = document.getElementById('league-dropdown');
    if (dd) dd.classList.remove('open');
    // Close any open "min. N makes to qualify" tooltip — verbatim from the app.
    // The button's own onclick calls stopPropagation() so opening one doesn't
    // immediately re-close it here.
    document.querySelectorAll('.pct-qual-btn.tip-open').forEach(function (b) { b.classList.remove('tip-open'); });
  });
  // Fire-and-forget visit tracking (feeds the /dashboard analytics), verbatim from the app.
  (function () {
    try {
      fetch('/a1a2-command-center/track', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          referrer: document.referrer || null,
          userAgent: navigator.userAgent,
          page: location.pathname + location.hash,
          src: new URLSearchParams(location.search).get('src') || null,
          title: trackTitleInit,
        }),
      }).catch(function () {});
    } catch (e) {}
  })();

  // Share button: native share sheet where supported, clipboard-copy fallback
  // otherwise. Only tracked on an actual completed share/copy — a cancelled
  // native share sheet doesn't count.
  (function () {
    var btn = document.getElementById('share-btn');
    if (!btn) return;
    function toast(msg) {
      var el = document.getElementById('share-toast');
      if (!el) {
        el = document.createElement('div');
        el.id = 'share-toast';
        el.className = 'share-toast';
        document.body.appendChild(el);
      }
      el.textContent = msg;
      requestAnimationFrame(function () { el.classList.add('show'); });
      clearTimeout(el._t);
      el._t = setTimeout(function () { el.classList.remove('show'); }, 2000);
    }
    function trackShare(method) {
      try {
        fetch('/a1a2-command-center/track-share', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ page: location.pathname, title: trackTitleInit, url: location.href, method: method }),
          keepalive: true,
        }).catch(function () {});
      } catch (e) {}
    }
    btn.addEventListener('click', function () {
      var shareData = { title: document.title, url: location.href };
      if (navigator.share) {
        navigator.share(shareData).then(function () { trackShare('native'); }).catch(function () {});
      } else if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(location.href).then(function () {
          toast('Link copied!');
          trackShare('clipboard');
        }).catch(function () { toast('Could not copy link'); });
      }
    });
  })();

  // Site-wide click tracking (feeds the /dashboard "Clicks" section): one
  // delegated listener catches every interactive element on every page, so
  // nothing needs its own tracking wire-up. Explicit data-track="..." on an
  // element (or ancestor) wins; otherwise a small set of known UI patterns get
  // a clean label, falling back to a generic "link"/tag-based one so nothing
  // clickable goes untracked. Capture phase so it still fires even when a
  // handler further down calls stopPropagation() (e.g. the league pill).
  (function () {
    var SELECTOR = 'a, button, input[type="search"], th[id^="th-"], .cmp-slot, .picker-item, [data-track]';
    function label(el) {
      var tracked = el.closest('[data-track]');
      if (tracked) return tracked.getAttribute('data-track');
      if (el.matches('th[id^="th-"]')) return 'stats:sort-' + el.id.slice(3);
      if (el.classList.contains('cmp-slot')) return 'compare:slot-open';
      if (el.classList.contains('picker-item')) return 'compare:pick';
      if (el.tagName === 'A') return 'link';
      if (el.tagName === 'BUTTON') return el.id ? 'button:' + el.id : 'button';
      return el.tagName.toLowerCase();
    }
    function detail(el) {
      if (el.tagName === 'A' && el.getAttribute('href')) return el.getAttribute('href');
      if (el.dataset && el.dataset.slug) return el.dataset.slug;
      if (el.id === 'league-pill') {
        var lbl = document.getElementById('league-pill-label');
        return lbl ? lbl.textContent.trim() : null;
      }
      var t = (el.textContent || '').trim().replace(/\s+/g, ' ');
      return t ? t.slice(0, 100) : null;
    }
    document.addEventListener('click', function (e) {
      var el = e.target.closest(SELECTOR);
      if (!el) return;
      try {
        fetch('/a1a2-command-center/track-click', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ label: label(el), detail: detail(el), page: location.pathname }),
          keepalive: true,
        }).catch(function () {});
      } catch (err) {}
    }, true);
  })();
</script>
</body>
</html>
