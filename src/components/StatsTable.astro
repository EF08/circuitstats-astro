---
// StatsTable.astro — the pre-SEO stats-table view (view-stats) as a real page.
// Server-rendered sorted by PPG desc (the app's default), ALL rows present so
// nothing is hidden behind JS/pagination. A client island (StatsTableInteractive)
// layers the app's exact click-to-sort / search / name-expand back on top.
import { TBL_COLS, getColVal, sortCmp, fmtColVal, abbr, RANK_LABELS, PCT_MIN_MAKES, type Player } from '../lib/stats';
import type { League } from '../lib/leagues';
import { rowLinks } from '../lib/links';

interface Props { league: League; rankJump?: { field: string; player: string } | null; }
const { league, rankJump = null } = Astro.props as Props;
const { players, ranks, standings, qualMin, combineKind } = league;
const RANK = ranks.RANK;

// Rank-jump mode (Abri short links / rank-chip landings): order by RANK[field]
// ascending, highlight one player, show the special meta line. Otherwise the
// normal PPG-desc default.
const rjActive = !!(rankJump && RANK[rankJump.field]);
const rankField = rjActive ? rankJump!.field : 'PPG';
let rows: Player[];
if (rjActive) {
  const rmap = RANK[rankJump!.field];
  rows = [...players].sort((a, b) => {
    const ra = rmap[a.Player] != null ? rmap[a.Player] : 1e9;
    const rb = rmap[b.Player] != null ? rmap[b.Player] : 1e9;
    return ra - rb || a.Player.localeCompare(b.Player);
  });
} else {
  rows = [...players].sort((a, b) => {
    const col = TBL_COLS.find(c => c.f === 'PPG')!;
    return sortCmp(a, b, 'PPG', getColVal(a, col), getColVal(b, col), 'desc', qualMin);
  });
}
const rjPlayerRank = rjActive ? RANK[rankJump!.field][rankJump!.player] : null;
const rjLabel = rjActive ? (RANK_LABELS[rankJump!.field] || rankJump!.field) : '';

function tagBadge(p: Player): string {
  if (combineKind === 'circuit' && p._age) return `<span class="age-badge">${p._age}</span>`;
  if (combineKind === 'age' && p._src) return `<span class="age-badge">${p._src || 'Multi'}</span>`;
  if (combineKind === 'all' && p._tag) return `<span class="age-badge">${p._tag}</span>`;
  return '';
}
const total = rows.length;
---
<div class="view active" id="view-stats">
  <div class="stats-top-bar">
    <div class="srch-wrap">
      <svg class="srch-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.35-4.35"></path>
      </svg>
      <input class="srch-inp" id="tbl-search" type="search" placeholder="Search players or teams&hellip;"
        autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" data-track="stats:search" />
      <button class="clear-x" id="tbl-clear" data-track="stats:search-clear">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="15" height="15">
          <path d="M18 6 6 18M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    {rjActive
      ? <div class="tbl-meta" id="tbl-meta" set:html={`<strong style="color:var(--accent)">${rankJump!.player}</strong> &middot; <strong style="color:var(--accent)">#${rjPlayerRank}</strong> of ${total} in ${rjLabel} &nbsp;<a href="${league.urlBase}/stats" data-track="stats:rank-jump-clear" style="text-decoration:underline;color:var(--text-3)">clear</a>`} />
      : <div class="tbl-meta" id="tbl-meta">Showing {total} of {total} player{total !== 1 ? 's' : ''} · tap column to sort</div>}
  </div>
  <div class="tbl-wrap">
    <table class="tbl" id="main-table">
      <thead id="main-thead">
        <tr>
          <th class="player-th">Player <button class="name-toggle-btn" id="name-toggle-btn" data-track="stats:name-toggle">+</button></th>
          {TBL_COLS.map(c => (
            <th id={`th-${c.f}`} class={(!rjActive && c.f === 'PPG') ? 'sorted' : undefined}>
              {c.h} <span class="sort-arrow" id={`arr-${c.f}`}>{(!rjActive && c.f === 'PPG') ? '↓' : ''}</span>{c.pct && (
                <button class="pct-qual-btn" data-track="stats:pct-tooltip" onclick="event.stopPropagation();this.classList.toggle('tip-open')">?<span class="pct-qual-tip">min. {qualMin} makes to qualify</span></button>
              )}
            </th>
          ))}
        </tr>
      </thead>
      <tbody id="main-tbody">
        {rows.map(p => {
          const { playerHref, teamHref } = rowLinks(p, league);
          const rnk = RANK[rankField] && RANK[rankField][p.Player];
          const seed = standings[p.Team] ? `#${standings[p.Team].rank} ` : '';
          const hl = rjActive && p.Player === rankJump!.player;
          return (
            <tr class={hl ? 'tbl-row-hl' : undefined}>
              <td class="tbl-td player-td">
                <a class="tbl-pname" href={playerHref} data-abbr={abbr(p.Player)} data-full={p.Player} data-track="stats:player-link">{abbr(p.Player)}{rnk && <span class="tbl-stat-rank">#{rnk}</span>}<Fragment set:html={tagBadge(p)} /></a>
                {teamHref
                  ? <a class="tbl-pteam" href={teamHref} data-track="stats:team-link">{seed}{p.Team}</a>
                  : <span class="tbl-pteam">{seed}{p.Team}</span>}
              </td>
              {TBL_COLS.map(c => {
                const makesField = PCT_MIN_MAKES[c.f];
                const qualifies = makesField ? ((p[makesField] || 0) >= qualMin ? '1' : '0') : undefined;
                return <td class="tbl-td" data-qualifies={qualifies}>{fmtColVal(p, c)}</td>;
              })}
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
  <button id="tbl-show-more" style="display:none" data-track="stats:show-more"></button>
</div>

<script is:inline define:vars={{ rjActiveInit: rjActive, rjFieldInit: rjActive ? rankJump!.field : null }}>
  // Progressive enhancement: click-to-sort, search-filter, name expand/collapse,
  // and pagination (100 at a time — the full dataset is already server-rendered
  // above for SEO/no-JS, this just keeps the *visible*/interactive DOM small so
  // sorting/scrolling stays fast on scopes with thousands of rows).
  (function () {
    var table = document.getElementById('main-table');
    if (!table) return;
    var tbody = document.getElementById('main-tbody');
    var meta = document.getElementById('tbl-meta');
    var ths = table.querySelectorAll('thead th');
    var cols = []; // {field, thIndex}
    ths.forEach(function (th, i) { if (th.id && th.id.indexOf('th-') === 0) cols.push({ field: th.id.slice(3), idx: i }); });
    var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
    var curField = 'PPG', curDir = 'desc';
    var pctBottom = { '—': 1, 'null': 1, 'null%': 1, 'N/A': 1 };

    var PAGE_SIZE = 100;
    var limit = PAGE_SIZE;
    var query = '';
    var rjActive = !!rjActiveInit; // rank-jump mode: show every row, no pagination
    var srch = document.getElementById('tbl-search');
    var clr = document.getElementById('tbl-clear');
    var showMoreBtn = document.getElementById('tbl-show-more');
    var wrapEl = document.querySelector('.tbl-wrap');
    var showMoreObserver = null;
    // Logical sort order (all rows, cheap in-memory array — updated by
    // applySort()). Only the *visible window* of this ever gets physically
    // reordered in the DOM; see applyVisibility().
    var sortedOrder = rows;
    // What's currently shown, so later calls only need to touch what *changed*
    // instead of re-scanning the whole (~2900-row) dataset every time. null the
    // first time through: the server-rendered page shows every row, so the
    // very first applyVisibility() call still has to hide everyone past the
    // first page once — same one-time cost the page always had.
    var prevVisible = null;

    function applyVisibility() {
      var ql = query.toLowerCase();
      // No active search (the common case — every sort click and "show more"
      // click runs through here) — skip the per-row querySelector matching
      // entirely instead of doing it and throwing the result away.
      var matched = ql
        ? sortedOrder.filter(function (r) {
            var nm = r.querySelector('.tbl-pname'), tm = r.querySelector('.tbl-pteam');
            var name = (nm && nm.getAttribute('data-full') || '').toLowerCase();
            var team = (tm && tm.textContent || '').toLowerCase();
            return name.indexOf(ql) >= 0 || team.indexOf(ql) >= 0;
          })
        : sortedOrder;
      var total = matched.length;
      var effLimit = rjActive ? total : Math.min(limit, total);
      var visible = matched.slice(0, effLimit);

      // The expensive part isn't computing the order (cheap array ops above) —
      // it's touching/repositioning DOM nodes. On a ~2900-row scope, reordering
      // *everything* on every sort/search call (even off-DOM in a fragment)
      // still means the browser has to re-layout/repaint a subtree that size.
      // So: only ever physically reposition the rows that are actually going
      // to be visible (bounded by the page size, not the dataset), and just
      // flip display:none on anything else that needs hiding — no reordering
      // for rows nobody can see yet.
      var visibleSet = new Set(visible);
      if (prevVisible === null) {
        // First run only: the server-rendered page shows every row, so this
        // one-time pass has to check everyone. Same cost the page always had.
        rows.forEach(function (r) { if (!visibleSet.has(r)) r.style.display = 'none'; });
      } else {
        // Every later call: only re-hide rows that *were* visible and no
        // longer are — bounded by the page size, not the full dataset.
        prevVisible.forEach(function (r) { if (!visibleSet.has(r)) r.style.display = 'none'; });
      }
      var frag = document.createDocumentFragment();
      visible.forEach(function (r) {
        if (r.style.display !== '') r.style.display = '';
        frag.appendChild(r);
      });
      tbody.appendChild(frag);
      prevVisible = visibleSet;

      if (meta) meta.textContent = 'Showing ' + effLimit + ' of ' + total + ' player' + (total !== 1 ? 's' : '') + ' · tap column to sort';
      if (clr) clr.classList.toggle('on', !!query);

      if (showMoreObserver) { showMoreObserver.disconnect(); showMoreObserver = null; }
      if (!showMoreBtn) return;
      if (!rjActive && effLimit < total) {
        showMoreBtn.textContent = 'Show next ' + Math.min(PAGE_SIZE, total - effLimit);
        showMoreBtn.style.display = 'none'; // hidden until last visible row scrolls into view
        var lastRow = matched[effLimit - 1];
        if (lastRow && wrapEl) {
          showMoreObserver = new IntersectionObserver(function (entries) {
            if (entries[0].isIntersecting) {
              showMoreBtn.style.display = '';
              showMoreObserver.disconnect(); showMoreObserver = null;
            }
          }, { root: wrapEl, threshold: 0.5 });
          showMoreObserver.observe(lastRow);
        }
      } else {
        showMoreBtn.style.display = 'none';
      }
    }
    if (showMoreBtn) showMoreBtn.addEventListener('click', function () {
      limit += PAGE_SIZE;
      applyVisibility();
    });

    function cellNum(tr, colIdx) {
      var td = tr.children[colIdx]; if (!td) return -Infinity;
      var t = td.textContent.trim();
      if (pctBottom[t] || t === '') return -Infinity;
      var v = parseFloat(t.replace('%', ''));
      return isNaN(v) ? -Infinity : v;
    }
    function playerName(tr) {
      var nm = tr.querySelector('.tbl-pname');
      return (nm && nm.getAttribute('data-full')) || '';
    }
    function applySort() {
      var col = cols.find(function (c) { return c.field === curField; });
      if (!col) return;

      // Read each row's value/qualification/name from the DOM exactly once —
      // sort() does O(n log n) comparisons, and re-reading the DOM inside the
      // comparator (on scopes with ~2900 rows) was most of the click-to-sort lag.
      var entries = rows.map(function (r) {
        var td = r.children[col.idx];
        var qAttr = td ? td.getAttribute('data-qualifies') : null;
        return {
          row: r,
          val: cellNum(r, col.idx),
          qualifies: qAttr == null ? null : qAttr !== '0',
          name: playerName(r),
        };
      });
      entries.sort(function (a, b) {
        // Qualifying-minimum columns (FG%/3P%/FT%/TS%): players below the makes
        // threshold always sink to the bottom, regardless of sort direction —
        // matches the server-rendered default sort (sortCmp in stats.ts).
        if (a.qualifies !== null || b.qualifies !== null) {
          var aQ = a.qualifies !== false, bQ = b.qualifies !== false;
          if (aQ !== bQ) return bQ ? 1 : -1;
          if (!aQ && !bQ) return a.name.localeCompare(b.name);
        }
        if (a.val === b.val) return 0;
        return curDir === 'desc' ? b.val - a.val : a.val - b.val;
      });
      // Just the logical order for now — no DOM writes here. applyVisibility()
      // (called below) is what actually repositions rows, and it only touches
      // the visible window, not this full ~2900-row array.
      sortedOrder = entries.map(function (e) { return e.row; });

      ths.forEach(function (th) {
        var arr = th.querySelector('.sort-arrow'); if (!arr) return;
        var on = th.id === 'th-' + curField;
        th.classList.toggle('sorted', on);
        arr.textContent = on ? (curDir === 'desc' ? '↓' : '↑') : '';
      });
      rjActive = false; // header click exits rank-jump mode, same as the original
      limit = PAGE_SIZE;
      applyVisibility();
    }
    ths.forEach(function (th) {
      if (!th.id || th.id.indexOf('th-') !== 0) return;
      th.style.cursor = 'pointer';
      th.addEventListener('click', function (e) {
        if (e.target.closest('.pct-qual-btn')) return;
        var f = th.id.slice(3);
        if (f === curField) curDir = curDir === 'desc' ? 'asc' : 'desc';
        else { curField = f; curDir = 'desc'; }
        applySort();
      });
    });
    // name expand/collapse
    var toggleBtn = document.getElementById('name-toggle-btn');
    var expanded = false;
    if (toggleBtn) toggleBtn.addEventListener('click', function () {
      expanded = !expanded;
      toggleBtn.textContent = expanded ? '−' : '+';
      tbody.querySelectorAll('.tbl-pname').forEach(function (a) {
        var want = expanded ? a.getAttribute('data-full') : a.getAttribute('data-abbr');
        if (a.firstChild && a.firstChild.nodeType === 3) a.firstChild.nodeValue = want;
        else a.insertBefore(document.createTextNode(want), a.firstChild);
      });
    });
    // search — also exits rank-jump mode and resets pagination, like the original
    if (srch) srch.addEventListener('input', function (e) {
      rjActive = false;
      limit = PAGE_SIZE;
      query = e.target.value;
      applyVisibility();
    });
    if (clr) clr.addEventListener('click', function () {
      srch.value = '';
      rjActive = false;
      limit = PAGE_SIZE;
      query = '';
      applyVisibility();
    });

    if (!rjActive) applyVisibility();

    // Rank-jump landing: replicate the pre-SEO app's snap-scroll (applyRankJump's
    // center()) — center the highlighted row vertically in the table's own scroll
    // container and, on mobile, pan horizontally so the jumped stat's column sits
    // right next to the sticky player column. Retried across frames + delayed
    // passes because on a cold / mobile load the flex layout (and the table's
    // final height) isn't settled on the first frame. Both axes are always
    // specified so the horizontal pan can't reset the vertical position.
    if (rjActive && rjFieldInit) {
      var centerJump = function () {
        var row = tbody.querySelector('.tbl-row-hl');
        if (!wrapEl || !row) return;
        var wrapRect = wrapEl.getBoundingClientRect();
        var rowRect = row.getBoundingClientRect();
        var top = Math.max(0, wrapEl.scrollTop + (rowRect.top - wrapRect.top) - (wrapEl.clientHeight / 2) + (rowRect.height / 2));
        var left = wrapEl.scrollLeft;
        var th = document.getElementById('th-' + rjFieldInit);
        if (window.innerWidth < 900 && th) {
          var thRect = th.getBoundingClientRect();
          var playerTh = document.querySelector('.player-th');
          var playerW = (playerTh && playerTh.offsetWidth) || 120;
          left = Math.max(0, wrapEl.scrollLeft + thRect.left - wrapRect.left - playerW);
        }
        wrapEl.scrollTo({ top: top, left: left, behavior: 'smooth' });
      };
      requestAnimationFrame(function () { requestAnimationFrame(centerJump); });
      setTimeout(centerJump, 80);   // fallback when rAF is throttled (just-loaded tab)
      setTimeout(centerJump, 300);  // second pass once flex layout / fonts have settled
    }
  })();

  // Axis-lock scroll + momentum (verbatim from the pre-SEO app): once a touch
  // gesture commits to horizontal or vertical, it stays locked to that axis
  // instead of panning both at once.
  (function axisLock() {
    var startX, startY, prevX, prevY, prevT;
    var velX = 0, velY = 0, axis = null, rafId = null;
    var FRICTION = 0.93;
    var wrap = document.querySelector('.tbl-wrap');
    if (!wrap) return;

    function decelerate() {
      velX *= FRICTION;
      velY *= FRICTION;
      if (Math.abs(velX) + Math.abs(velY) < 0.5) return;
      if (axis === 'x') wrap.scrollLeft -= velX;
      else wrap.scrollTop -= velY;
      rafId = requestAnimationFrame(decelerate);
    }

    wrap.addEventListener('touchstart', function (e) {
      cancelAnimationFrame(rafId);
      var t = e.touches[0];
      startX = prevX = t.clientX;
      startY = prevY = t.clientY;
      prevT = performance.now();
      velX = velY = 0;
      axis = null;
    }, { passive: true });

    wrap.addEventListener('touchmove', function (e) {
      var now = performance.now();
      var x = e.touches[0].clientX;
      var y = e.touches[0].clientY;
      var dx = x - prevX;
      var dy = y - prevY;
      var dt = Math.max(1, now - prevT);

      if (!axis) {
        var tx = Math.abs(x - startX), ty = Math.abs(y - startY);
        if (tx > 6 || ty > 6) axis = tx >= ty ? 'x' : 'y';
      }

      if (axis) {
        e.preventDefault();
        if (axis === 'x') { wrap.scrollLeft -= dx; velX = dx / dt * 16; }
        else { wrap.scrollTop -= dy; velY = dy / dt * 16; }
      }

      prevX = x; prevY = y; prevT = now;
    }, { passive: false });

    wrap.addEventListener('touchend', function () {
      rafId = requestAnimationFrame(decelerate);
    }, { passive: true });
  })();
</script>
