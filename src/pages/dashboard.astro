---
// /dashboard — owner analytics, ported from the pre-SEO app then simplified per
// Andy's request: real page-view traffic (who's actually looking at which
// player/team/comparison), not raw click-event labels. Client-rendered after
// auth: the GateModal (in Layout) redeems a magic link / stored token; then
// renderDashboard() fetches the backend. noindex.
import Layout from '../layouts/Layout.astro';
const SITE = 'https://www.circuitstats.com';
---
<Layout
  title="Dashboard | Circuit Stats"
  subLabel="Owner analytics"
  pillLabel="ALL"
  pageBase="/rankings"
  activeTab={null}
  canonical={`${SITE}/dashboard`}
  robots="noindex,nofollow"
>
  <div style="padding:20px 16px 40px;max-width:700px;margin:0 auto">
    <h2 style="font-size:20px;font-weight:800;margin-bottom:4px">Circuit Stats Dashboard</h2>
    <p style="color:var(--text-2);font-size:13px;margin-bottom:24px">Visitor &amp; subscriber analytics &middot; human traffic only (bots are still recorded, just hidden here)</p>
    <div id="db-content" style="color:var(--text-2);font-size:13px">Loading…</div>
  </div>
</Layout>

<script is:inline>
  (function () {
    var GB = '/a1a2-command-center';

    function esc(s) { return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

    function statCard(label, value) {
      return '<div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:14px 16px">' +
        '<div style="font-size:22px;font-weight:800">' + esc(value) + '</div>' +
        '<div style="font-size:11px;color:var(--text-2);margin-top:2px">' + esc(label) + '</div></div>';
    }

    // A labeled horizontal bar per item, sized relative to the largest count.
    function barList(items, labelFn, countFn) {
      if (!items || !items.length) return '<div style="padding:12px 14px;font-size:12px;color:var(--text-3)">No data yet.</div>';
      var max = Math.max.apply(null, items.map(countFn).concat([1]));
      var rows = items.map(function (it) {
        var label = labelFn(it), count = countFn(it);
        var pct = Math.max(2, Math.round((count / max) * 100));
        return '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">' +
          '<div style="width:150px;font-size:12px;color:var(--text);flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">' + esc(label) + '</div>' +
          '<div style="flex:1;background:var(--surface);border-radius:4px;overflow:hidden;height:16px"><div style="width:' + pct + '%;background:var(--accent);height:100%"></div></div>' +
          '<div style="width:34px;text-align:right;font-size:12px;font-weight:700;flex-shrink:0">' + count + '</div></div>';
      }).join('');
      return '<div style="padding:12px 14px">' + rows + '</div>';
    }

    // Raw per-hit log — the "(per hit too)" drill-down under each aggregate.
    function hitTable(columns, rows) {
      if (!rows || !rows.length) return '<div style="padding:12px 14px;font-size:12px;color:var(--text-3)">No hits yet.</div>';
      var head = columns.map(function (c) { return '<th style="padding:6px 8px;font-size:10px;color:var(--text-2);text-align:left;font-weight:600;white-space:nowrap">' + esc(c.h) + '</th>'; }).join('');
      var body = rows.map(function (r) {
        return '<tr style="border-bottom:1px solid var(--border)">' + columns.map(function (c) {
          return '<td style="padding:6px 8px;font-size:11px;color:var(--text-2);max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">' + esc(c.v(r)) + '</td>';
        }).join('') + '</tr>';
      }).join('');
      return '<div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse"><thead><tr style="border-bottom:1px solid var(--border)">' + head + '</tr></thead><tbody>' + body + '</tbody></table></div>';
    }

    function card(title, sub, bodyHtml) {
      return '<div style="background:var(--card);border:1px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:20px">' +
        '<div style="padding:12px 14px;border-bottom:1px solid var(--border)"><div style="font-size:13px;font-weight:700">' + title + '</div>' +
        (sub ? '<div style="font-size:11px;color:var(--text-3);margin-top:1px">' + sub + '</div>' : '') + '</div>' +
        bodyHtml + '</div>';
    }
    function subHeading(text) {
      return '<div style="padding:10px 14px 2px;font-size:11px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.4px">' + esc(text) + '</div>';
    }

    // page/title fallback: show the friendly name if we have it (visits tracked
    // after this feature shipped), else the raw path (older visits).
    function nameOf(row) { return row.title || row.page || '—'; }
    function locOf(row) { return row.location || '—'; }

    async function renderDashboard() {
      var token = localStorage.getItem('cb_token');
      if (!token) {
        document.getElementById('db-content').textContent = 'Sign in with the owner account to view analytics.';
        if (window.gateOpen) window.gateOpen();   // matches the pre-SEO app: pop the sign-in modal
        return;
      }
      try {
        var statsRes = await fetch(GB + '/dashboard/stats?limit=1', { headers: { 'Authorization': 'Bearer ' + token } });
        if (statsRes.status === 403) { document.getElementById('db-content').textContent = 'Owner access only.'; return; }
        if (!statsRes.ok) throw new Error('HTTP ' + statsRes.status);
        var d = await statsRes.json();

        var trafficRes = await fetch(GB + '/dashboard/traffic?limit=15', { headers: { 'Authorization': 'Bearer ' + token } });
        var t = trafficRes.ok ? await trafficRes.json() : null;

        var sharesRes = await fetch(GB + '/dashboard/shares?limit=15', { headers: { 'Authorization': 'Bearer ' + token } });
        var sh = sharesRes.ok ? await sharesRes.json() : null;

        var maxDay = Math.max.apply(null, d.visitsByDay.map(function (x) { return x.count; }).concat([1]));
        var byDayBars = d.visitsByDay.slice(-14).map(function (r) {
          var pct = Math.round((r.count / maxDay) * 100);
          return '<div title="' + r._id + ': ' + r.count + '" style="display:flex;align-items:flex-end;gap:3px;flex-direction:column"><div style="width:24px;background:var(--accent);border-radius:3px 3px 0 0;height:' + Math.max(4, pct * 0.8) + 'px;opacity:.8"></div><div style="font-size:8px;color:var(--text-3);transform:rotate(-40deg);transform-origin:top right;white-space:nowrap">' + r._id.slice(5) + '</div></div>';
        }).join('');
        var subRows = (d.subscribers && d.subscribers.recent || []).map(function (s) {
          return '<tr style="border-bottom:1px solid var(--border)"><td style="padding:6px 8px;font-size:12px">' + esc(s.email) + '</td><td style="padding:6px 8px;font-size:11px;color:var(--accent)">' + esc(s.plan) + '</td><td style="padding:6px 8px;font-size:11px;color:var(--text-2)">' + (s.createdAt ? new Date(s.createdAt).toLocaleDateString() : '') + '</td></tr>';
        }).join('');

        var overviewStats = [['Human Visits', d.humanVisits != null ? d.humanVisits : d.totalVisits], ['Unique IPs', d.uniqueIpCount], ['Subscribers', (d.subscribers && d.subscribers.total) != null ? d.subscribers.total : '—']];

        var html = '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px">' + overviewStats.map(function (p) { return statCard(p[0], p[1]); }).join('') + '</div>';
        html += card('Visits — last 14 days', null, '<div style="padding:14px;display:flex;align-items:flex-end;gap:4px;height:90px">' + byDayBars + '</div>');

        if (t) {
          // 1. Overall website traffic — where it's coming from + a per-hit log.
          html += card(
            'Overall Website Traffic',
            t.totalHumanVisits + ' human visits tracked',
            subHeading('Traffic sources') + barList(t.topReferrers, function (r) { return r.host; }, function (r) { return r.count; }) +
            subHeading('Recent hits') + hitTable(
              [{ h: 'Time', v: function (r) { return r.displayTime; } },
               { h: 'Page', v: function (r) { return r.title || r.page; } },
               { h: 'From', v: function (r) { return r.referrer ? (function () { try { return new URL(r.referrer).hostname; } catch (e) { return r.referrer; } })() : 'Direct'; } },
               { h: 'Location', v: locOf }],
              t.recentHits
            )
          );

          // 2. Player page traffic
          html += card(
            'Player Page Traffic',
            t.player.total + ' player-page views',
            subHeading('Most-viewed players') + barList(t.player.top, nameOf, function (r) { return r.count; }) +
            subHeading('Recent views') + hitTable(
              [{ h: 'Time', v: function (r) { return r.displayTime; } },
               { h: 'Player', v: nameOf },
               { h: 'Location', v: locOf }],
              t.player.recent
            )
          );

          // 3. Team page traffic
          html += card(
            'Team Page Traffic',
            t.team.total + ' team-page views',
            subHeading('Most-viewed teams') + barList(t.team.top, nameOf, function (r) { return r.count; }) +
            subHeading('Recent views') + hitTable(
              [{ h: 'Time', v: function (r) { return r.displayTime; } },
               { h: 'Team', v: nameOf },
               { h: 'Location', v: locOf }],
              t.team.recent
            )
          );

          // 4. Comparisons — per-player attribution (a view of "A vs B" counts
          // once for A and once for B) plus the exact match-ups themselves.
          html += card(
            'Comparisons',
            t.compare.total + ' comparison views',
            subHeading('Most-compared players') + barList(t.compare.topPlayers, function (r) { return r.name; }, function (r) { return r.count; }) +
            subHeading('Most-viewed match-ups') + barList(t.compare.topPairs, nameOf, function (r) { return r.count; }) +
            subHeading('Recent comparisons') + hitTable(
              [{ h: 'Time', v: function (r) { return r.displayTime; } },
               { h: 'Match-up', v: nameOf },
               { h: 'Location', v: locOf }],
              t.compare.recent
            )
          );
        }

        if (sh) {
          // Shares: what's actually getting shared (native share sheet or the
          // clipboard-copy fallback), broken into the same buckets as traffic.
          var shareTop = [].concat(
            sh.player.top.map(function (r) { return { label: nameOf(r), count: r.count }; }),
            sh.team.top.map(function (r) { return { label: nameOf(r), count: r.count }; }),
            sh.compare.top.map(function (r) { return { label: nameOf(r), count: r.count }; })
          ).sort(function (a, b) { return b.count - a.count; }).slice(0, 15);
          html += card(
            'Shares',
            sh.totalShares + ' total shares (player, team &amp; comparison pages)',
            subHeading('Most-shared pages') + barList(shareTop, function (r) { return r.label; }, function (r) { return r.count; }) +
            subHeading('Recent shares') + hitTable(
              [{ h: 'Time', v: function (r) { return r.displayTime; } },
               { h: 'Page', v: nameOf },
               { h: 'Via', v: function (r) { return r.method === 'native' ? 'Share sheet' : 'Copied link'; } },
               { h: 'Location', v: locOf }],
              sh.recent
            )
          );
        }

        if (subRows) html += card('Subscribers', null, '<table style="width:100%;border-collapse:collapse"><tbody>' + subRows + '</tbody></table>');

        document.getElementById('db-content').innerHTML = html;
      } catch (e) { document.getElementById('db-content').textContent = 'Error loading stats: ' + e.message; }
    }
    // GateModal's gateVerify() (in Layout) may redeem a magic link async; re-run
    // the dashboard once it settles, and expose a hook for immediate unlock.
    window.onGateUnlock = renderDashboard;
    if (new URLSearchParams(location.search).has('auth')) {
      // magic link present — wait for GateModal.gateVerify() to redeem it, then
      // onGateUnlock fires renderDashboard. Avoids a premature sign-in prompt.
      document.getElementById('db-content').textContent = 'Signing you in…';
    } else {
      renderDashboard();
    }
  })();
</script>
