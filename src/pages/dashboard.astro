      'Pakistan':[30.4,69.3],'Bangladesh':[23.7,90.4],'China':[35.9,104.2],'Japan':[36.2,138.3],
      'South Korea':[35.9,127.8],'Taiwan':[23.7,121.0],'Hong Kong':[22.3,114.2],'Singapore':[1.35,103.8],
      'Malaysia':[4.2,101.98],'Indonesia':[-0.8,113.9],'Thailand':[15.9,101.0],'Vietnam':[14.06,108.3],
      'Philippines':[12.9,121.8],'Australia':[-25.3,133.8],'New Zealand':[-40.9,174.9],
      'Kazakhstan':[48.0,66.9],'Uzbekistan':[41.4,64.6],'Georgia':[42.3,43.4],'Armenia':[40.1,45.0],
      'Serbia':[44.0,21.0],'Croatia':[45.1,15.2],'Slovenia':[46.2,15.0],'Bosnia and Herzegovina':[43.9,17.7],
      'North Macedonia':[41.6,21.7],'Albania':[41.2,20.2],'Moldova':[47.4,28.4],'Belarus':[53.7,27.95],
      'Qatar':[25.4,51.2],'Kuwait':[29.3,47.5],'Jordan':[30.6,36.2],'Lebanon':[33.9,35.9],
      'Iraq':[33.2,43.7],'Iran':[32.4,53.7],'Nepal':[28.4,84.1],'Sri Lanka':[7.9,80.8],
      'Costa Rica':[9.7,-83.8],'Panama':[8.5,-80.8],'Dominican Republic':[18.7,-70.2],
      'Jamaica':[18.1,-77.3],'Trinidad and Tobago':[10.7,-61.2],'Puerto Rico':[18.2,-66.6],
      'Bahamas':[25.0,-77.4],'Guatemala':[15.8,-90.2],'Honduras':[15.2,-86.2],'Ecuador':[-1.8,-78.2],
      'Venezuela':[6.4,-66.6],'Uruguay':[-32.5,-55.8],'Paraguay':[-23.4,-58.4],'Bolivia':[-16.3,-63.6]
    };

    // Bubble area (not radius) tracks the count, so a country with twice the
    // visitors looks twice as big rather than four times.
    function geoMap(geo) {
      var placed = (geo || []).filter(function (g) { return CENTROIDS[g.country]; });
      if (!placed.length) return '';
      // Crop the empty polar bands — nothing lives above 78N or below 56S, and
      // including them wasted half the height and shrank every bubble.
      var LAT_TOP = 78, LAT_BOT = -56;
      var W = 720, H = Math.round(W * (LAT_TOP - LAT_BOT) / 360);
      var max = placed[0].people || 1;
      var x = function (lon) { return (lon + 180) / 360 * W; };
      var y = function (lat) { return (LAT_TOP - lat) / (LAT_TOP - LAT_BOT) * H; };

      // A faint graticule so the bubbles read as positions on a globe rather
      // than a scatter plot. Equator and prime meridian a step stronger, since
      // those are the two lines people orient from.
      var grid = '';
      for (var lon = -150; lon <= 150; lon += 30) {
        grid += '<line x1="' + x(lon).toFixed(1) + '" y1="0" x2="' + x(lon).toFixed(1) + '" y2="' + H +
          '" stroke="var(--grid)" stroke-width="' + (lon === 0 ? 1.4 : 0.7) + '"/>';
      }
      for (var lat = -40; lat <= 60; lat += 20) {
        grid += '<line x1="0" y1="' + y(lat).toFixed(1) + '" x2="' + W + '" y2="' + y(lat).toFixed(1) +
          '" stroke="var(--grid)" stroke-width="' + (lat === 0 ? 1.4 : 0.7) + '"/>';
      }

      // Bubble area (not radius) tracks the count, so twice the visitors looks
      // twice as big rather than four times.
      var geom = placed.map(function (g) {
        var c = CENTROIDS[g.country];
        return { g: g, cx: x(c[1]), cy: y(c[0]), r: Math.max(4, Math.sqrt(g.people / max) * 30) };
      });

      var bubbles = geom.map(function (b, i) {
        var cities = b.g.cities.slice(0, 4).map(function (ct) { return ct.city + ' (' + ct.people + ')'; }).join(' · ');
        return '<g class="geo-b" data-i="' + i + '" data-country="' + esc(b.g.country) +
          '" data-people="' + b.g.people + '" data-cities="' + esc(cities) + '">' +
          '<circle cx="' + b.cx.toFixed(1) + '" cy="' + b.cy.toFixed(1) + '" r="' + b.r.toFixed(1) +
          '" fill="' + BUBBLE + '" fill-opacity=".28" stroke="' + BUBBLE + '" stroke-width="1.5"/>' +
          // Generous invisible hit area — a 4px bubble is impossible to hover.
          '<circle cx="' + b.cx.toFixed(1) + '" cy="' + b.cy.toFixed(1) + '" r="' +
          Math.max(b.r, 13).toFixed(1) + '" fill="transparent"/></g>';
      }).join('');

      // Label the leaders only, with greedy collision avoidance: try above the
      // bubble, then below, then give up. Canada and the USA sit close enough
      // that their labels overlapped and both became unreadable.
      var boxes = [], labels = '';
      geom.slice(0, 5).forEach(function (b) {
        var name = b.g.country === 'United States' ? 'USA' : b.g.country;
        var w = name.length * 6.2, h = 13;
        var cands = [b.cy - b.r - 5, b.cy + b.r + 12];
        for (var k = 0; k < cands.length; k++) {
          var box = { x1: b.cx - w / 2, x2: b.cx + w / 2, y1: cands[k] - h, y2: cands[k] };
          var hits = boxes.some(function (o) {
            return !(box.x2 < o.x1 || box.x1 > o.x2 || box.y2 < o.y1 || box.y1 > o.y2);
          });
          if (!hits) {
            boxes.push(box);
            labels += '<text x="' + b.cx.toFixed(1) + '" y="' + cands[k].toFixed(1) +
              '" text-anchor="middle" font-size="11" font-weight="700" fill="var(--text-2)">' +
              esc(name) + '</text>';
            return;
          }
        }
      });

      return '<div class="geo-wrap" id="geo-wrap">' +
        '<svg viewBox="0 0 ' + W + ' ' + H + '" role="img" aria-label="Visitors by country">' +
        '<path d="' + LAND_PATH + '" fill="var(--map-land)" stroke="var(--map-edge)" stroke-width="0.4" stroke-linejoin="round"/>' + grid + bubbles + labels + '</svg><div class="db-tip" id="geo-tip"></div></div>';
    }

    function wireGeo() {
      var wrap = document.getElementById('geo-wrap');
      if (!wrap) return;
      var tip = document.getElementById('geo-tip');
      wrap.querySelectorAll('.geo-b').forEach(function (g) {
        g.addEventListener('pointerenter', function () {
          var name = g.getAttribute('data-country');
          var ppl = g.getAttribute('data-people');
          var cities = g.getAttribute('data-cities');
          tip.innerHTML = '<div class="db-tip-d"></div>' +
            '<div class="db-tip-r"><span class="db-tip-v">' + ppl + '</span>' +
            '<span class="db-tip-n">' + (ppl === '1' ? 'person' : 'people') + '</span></div>' +
            (cities ? '<div class="db-tip-c"></div>' : '');
          tip.firstChild.textContent = name;
          if (cities) tip.lastChild.textContent = cities;
          tip.style.opacity = '1';
          // Position from the bubble's own box, in CSS pixels.
          var b = g.getBoundingClientRect(), hostR = wrap.getBoundingClientRect();
          var scale = wrap.clientWidth / (hostR.width || 1);
          var cx = (b.left + b.width / 2 - hostR.left) * scale;
          var cy = (b.top - hostR.top) * scale;
          var tw = tip.offsetWidth || 160;
          tip.style.left = Math.max(0, Math.min(wrap.clientWidth - tw, cx - tw / 2)) + 'px';
          tip.style.top = Math.max(0, cy - tip.offsetHeight - 8) + 'px';
        });
        g.addEventListener('pointerleave', function () { tip.style.opacity = '0'; });
      });
    }

    // ── Trend: small multiples ───────────────────────────────────────────────
    // Visits and page views are the same unit but wildly different magnitudes
    // (page views run ~7x visits). Plotted together on one axis the visits
    // line — the one that actually matters — flattens against the baseline;
    // plotted on two axes the chart would invent a correlation. So: two charts,
    // each scaled to its own data, sharing an x-axis. Each is a single series,
    // so neither needs a legend — the panel title names it.
    var TREND_W = 720, TREND_PL = 38, TREND_PR = 10;

    function trendPanel(byDay, key, title, hue, idx) {
      var W = TREND_W, H = 128, PL = TREND_PL, PR = TREND_PR, PT = 12, PB = 22;
      var iw = W - PL - PR, ih = H - PT - PB;
      var max = byDay.reduce(function (m, d) { return Math.max(m, d[key] || 0); }, 0) || 1;
      var mag = Math.pow(10, Math.floor(Math.log10(max)));
      var top = Math.ceil(max / (mag / 2 || 1)) * (mag / 2 || 1);
      var x = function (i) { return PL + (byDay.length === 1 ? iw / 2 : (i / (byDay.length - 1)) * iw); };
      var y = function (v) { return PT + ih - (v / top) * ih; };
      var line = byDay.map(function (d, i) { return (i ? 'L' : 'M') + x(i).toFixed(1) + ' ' + y(d[key] || 0).toFixed(1); }).join(' ');
      var area = line + ' L' + x(byDay.length - 1).toFixed(1) + ' ' + (PT + ih) + ' L' + x(0).toFixed(1) + ' ' + (PT + ih) + ' Z';

      var ticks = [0, top].map(function (v) {
        return '<line x1="' + PL + '" x2="' + (W - PR) + '" y1="' + y(v).toFixed(1) + '" y2="' + y(v).toFixed(1) + '" stroke="var(--grid)" stroke-width="1"/>' +
          '<text x="' + (PL - 8) + '" y="' + (y(v) + 3.5).toFixed(1) + '" text-anchor="end" font-size="10" fill="var(--text-3)">' + compact(Math.round(v)) + '</text>';
      }).join('');

      // Only the bottom panel carries date labels — they're shared.
      var xlabels = '';
      if (idx === 1) {
        var every = Math.max(1, Math.round(byDay.length / 6));
        xlabels = byDay.map(function (d, i) {
          if (i % every !== 0 && i !== byDay.length - 1) return '';
          return '<text x="' + x(i).toFixed(1) + '" y="' + (H - 6) + '" text-anchor="middle" font-size="10" fill="var(--text-3)">' + esc(shortDate(d.date)) + '</text>';
        }).join('');
      }
      var last = byDay.length - 1;
      var total = byDay.reduce(function (s, d) { return s + (d[key] || 0); }, 0);

      return '<div class="db-panel">' +
        '<div class="db-panel-h"><span class="db-panel-t">' + esc(title) + '</span>' +
        '<span class="db-panel-v">' + n(total) + '</span></div>' +
        '<div class="db-chart">' +
        '<svg viewBox="0 0 ' + W + ' ' + H + '" preserveAspectRatio="none" role="img" aria-label="Daily ' + esc(title.toLowerCase()) + '">' +
          ticks + xlabels +
          '<path d="' + area + '" fill="' + hue.fill + '"/>' +
          '<path d="' + line + '" fill="none" stroke="' + hue.line + '" stroke-width="2" stroke-linejoin="round" stroke-linecap="round" vector-effect="non-scaling-stroke"/>' +
          '<circle cx="' + x(last).toFixed(1) + '" cy="' + y(byDay[last][key] || 0).toFixed(1) + '" r="4" fill="' + hue.line + '" stroke="var(--card)" stroke-width="2"/>' +
          '<line class="db-cross" x1="0" x2="0" y1="' + PT + '" y2="' + (PT + ih) + '" stroke="' + hue.line + '" stroke-width="1" opacity="0"/>' +
        '</svg></div></div>';
    }

    function trendChart(byDay) {
      if (!byDay || byDay.length < 2) return '<div class="db-empty">Not enough days yet to draw a trend.</div>';
      return '<div class="db-trends" id="db-trend">' +
        trendPanel(byDay, 'arrivals', 'Visits', { line: 'var(--accent)', fill: 'rgba(79,142,247,.15)' }, 0) +
        trendPanel(byDay, 'pageviews', 'Page views', { line: 'rgba(126,166,232,.75)', fill: 'rgba(126,166,232,.10)' }, 1) +
        '<div class="db-tip" id="db-trend-tip"></div>' +
        '<div class="db-hitwrap" id="db-hit"></div>' +
        '</div>';
    }

    // One hit layer over both panels: the reader aims at a date, and both
    // crosshairs plus a single readout follow. The pointer never has to land on
    // a 2px line.
    function wireTrend(byDay) {
      var wrap = el('db-trend'); if (!wrap) return;
      var hit = el('db-hit'), tip = el('db-trend-tip');
      var crosses = wrap.querySelectorAll('.db-cross');
      if (!hit || !byDay.length) return;
      var W = TREND_W, PL = TREND_PL, iw = W - PL - TREND_PR;

      function show(evt) {
        var r = hit.getBoundingClientRect();
        var cx = evt.clientX != null ? evt.clientX : (evt.touches && evt.touches[0] && evt.touches[0].clientX);
        if (cx == null || !r.width) return;
        // The hit layer spans the same box as the plots, so fraction-of-width
        // maps straight onto the data index.
        var frac = (cx - r.left) / r.width;
        var i = Math.round(frac * (byDay.length - 1));
        i = Math.max(0, Math.min(byDay.length - 1, i));
        var d = byDay[i];
        var px = PL + (byDay.length === 1 ? iw / 2 : (i / (byDay.length - 1)) * iw);
        crosses.forEach(function (c) {
          c.setAttribute('x1', px); c.setAttribute('x2', px); c.setAttribute('opacity', '.45');
        });

        tip.innerHTML = '<div class="db-tip-d"></div>' +
          '<div class="db-tip-r"><i class="db-tip-k" style="background:var(--accent)"></i>' +
            '<span class="db-tip-v">' + n(d.arrivals) + '</span><span class="db-tip-n">visits</span></div>' +
          '<div class="db-tip-r"><i class="db-tip-k" style="background:rgba(126,166,232,.75)"></i>' +
            '<span class="db-tip-v">' + n(d.pageviews) + '</span><span class="db-tip-n">page views</span></div>' +
          '<div class="db-tip-r"><i class="db-tip-k" style="background:transparent"></i>' +
            '<span class="db-tip-v">' + n(d.people) + '</span><span class="db-tip-n">people</span></div>';
        // Dates come from our own aggregation, but keep the habit of not
        // concatenating data into innerHTML.
        tip.firstChild.textContent = longDate(d.date);
        tip.style.opacity = '1';

        // Placement must be computed in CSS pixels, not the visual pixels that
        // getBoundingClientRect returns. global.css applies html{zoom:1.3} above
        // 1024px, so a value derived from rects and then written to style.left
        // lands 1.3x too far right — which is why the tooltip escaped the card
        // (overflow:hidden) as the pointer moved right. offsetLeft/offsetWidth
        // are already CSS pixels and are immune to the zoom.
        //
        // The pointer→index mapping above stays on rects because it is a ratio,
        // so the scale cancels out.
        var hostW = wrap.clientWidth;
        var relX  = hit.offsetLeft + ((px - PL) / iw) * hit.offsetWidth;
        var tw    = tip.offsetWidth || 160;
        tip.style.left = Math.max(0, Math.min(hostW - tw, relX - tw / 2)) + 'px';
      }
      function hide() {
        tip.style.opacity = '0';
        crosses.forEach(function (c) { c.setAttribute('opacity', '0'); });
      }
      hit.addEventListener('pointermove', show);
      hit.addEventListener('pointerdown', show);
      hit.addEventListener('pointerleave', hide);
      hit.addEventListener('touchmove', function (e) { show(e); }, { passive: true });
      hit.addEventListener('touchend', hide);
    }

    // Grow bars in after paint so the funnel reads as a funnel filling up.
    function animate() {
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          document.querySelectorAll('[data-w]').forEach(function (b) {
            b.style.width = b.getAttribute('data-w') + '%';
          });
        });
      });
    }

    // ── Render ───────────────────────────────────────────────────────────────
    function render(data) {
      var a = data.audience, f = data.funnel;
      var rangeWord = (a.range && a.range.allTime) ? 'since launch' : 'last ' + days + ' days';
      var html = '';

      // ── 1. The verdict: leads, and the plain-English state of the funnel ──
      var leadN = f.leads.count;
      var conv = f.conversion.rate;
      var verdict, sub;
      if (leadN === 0) {
        var reached = (f.stages[3] || {}).people || 0;
        if (reached === 0) {
          verdict = '<span class="lo">Nobody even reached the offer page.</span> Of ' + n(f.stages[0].people) +
            ' visitors, none opened /get-started.';
        } else {
          verdict = n(reached) + ' ' + (reached === 1 ? 'person' : 'people') + ' read the pitch and <span class="lo">none requested a website</span>.';
        }
        // Name the step the data actually blames, rather than assuming it's the
        // pitch page — the biggest leak is usually further up, and a hardcoded
        // conclusion here would contradict the funnel directly beneath it.
        sub = f.leak
          ? 'Biggest leak: <strong>' + esc(f.leak.label) + '</strong> lost ' + n(f.leak.dropped) +
            ' people. Fix that step before spending anything on more traffic.'
          : 'Not enough traffic yet to say where it is failing.';
      } else {
        verdict = '<strong>' + n(leadN) + ' ' + (leadN === 1 ? 'lead' : 'leads') + '</strong> from ' +
          n(f.stages[0].people) + ' visitors — a ' + pct(conv, 2) + ' conversion rate.';
        sub = f.leak
          ? 'Biggest leak: <strong>' + esc(f.leak.label) + '</strong> lost ' + n(f.leak.dropped) + ' people.'
          : 'No single dominant drop-off.';
      }
      html += '<div class="db-verdict">' +
        '<div><div class="db-hero-n">' + n(leadN) + '</div>' +
        '<div class="db-hero-l">website ' + (leadN === 1 ? 'request' : 'requests') + ' · ' + rangeWord + '</div></div>' +
        '<div><div class="db-verdict-txt">' + verdict + '</div>' +
        '<div class="db-verdict-sub">' + sub + '</div></div></div>';

      // ── 2. Funnel ──
      var leadsDelta = delta(f.leads.delta, true);
      html += card(
        'Where the money is leaking',
        'Every step from landing on the site to asking for a website. Counted in <strong>people</strong>, not clicks — so each row is a human who reached that step.',
        funnelHtml(f),
        disclosure('What these steps mean, and how they\'re counted',
          '<div class="db-note">' +
          '<p style="margin-bottom:10px">Each stage counts <strong>unique people</strong> (by IP) who reached it in the selected range, and counts anyone who got further as having reached every step before it. That is why the funnel only ever narrows.</p>' +
          '<p style="margin-bottom:10px"><strong>"Clicked the offer" is partly inferred.</strong> ' + n(f.ctaClicks) + ' ' +
          (f.ctaClicks === 1 ? 'person was' : 'people were') + ' actually recorded clicking the button; ' + n(f.reachedDirectly) +
          ' more reached the pitch page some other way (a shared link, a bookmark, or the URL directly) and are counted at that step too. If you want the button\'s true click-through rate, use the recorded number.</p>' +
          '<p style="margin-bottom:10px"><strong>IP is a stand-in for a person.</strong> A family sharing one home connection reads as one person; a phone switching towers can read as several. Treat these as close, not exact.</p>' +
          '<p><strong>Form abandonment:</strong> ' + (f.form.starts > 0
            ? n(f.form.starts) + ' started filling the form, ' + n(f.form.completed) + ' finished — ' +
              pct(f.form.abandonRate, 0) + ' abandoned. ' + n(f.form.attempts) + ' submit presses, ' +
              n(f.form.errors) + ' failed with an error.'
            : 'Form-start tracking is new, so there is no abandonment data yet. Once visitors start touching the form, this will show how many fill fields in and leave without submitting.') + '</p>' +
          '</div>')
      );

      // ── 3. The offer page in particular ──
      var pitchReaders = (f.stages[3] || {}).people || 0;
      // Form-start tracking shipped with this dashboard, so before any visitor
      // has touched the form there is genuinely no data — which is a different
      // statement from "nobody started the form", and the tile must not print
      // a confident 0% for it.
      var formStartNote = f.form.starts > 0
        ? pct(pitchReaders ? f.form.starts / pitchReaders : 0, 0) + ' of pitch readers'
        : 'No form-starts recorded yet';
      html += '<div class="db-kpis">' +
        kpi('Read the pitch', n(pitchReaders), '', 'Landed on /get-started and saw the price') +
        kpi('Started the form', n(f.form.starts), '', formStartNote) +
        kpi('Requested a site', n(leadN), leadsDelta, '') +
        kpi('Viewed the example', n(f.example.people), '',
          f.example.people
            ? pct(f.example.ofPitchReaders, 0) + ' of pitch readers clicked through to abrifazliu.com' +
              (f.example.converted ? ' · ' + n(f.example.converted) + ' of them converted' : '')
            : 'Nobody clicked through to abrifazliu.com') +
        '</div>';

      // ── 3b. Who actually clicked, and who they were ──
      // "How many real people clicked Get D1 offers now on Trey Johnson's page"
      // — answerable because the click listener records the page it fired on.
      html += section('The offer', 'who clicked, and who they were');
      html += card('Offer clicks by player page',
        'Real people only — crawlers and your own visits are already removed. <strong>Get D1 offers</strong> goes to the pitch; <strong>See live example</strong> goes to abrifazliu.com.',
        table([
          { h: 'Player page', v: function (r) { return r.title || r.page; } },
          { h: 'Get D1 offers', v: function (r) { return r.getOffers ? n(r.getOffers) : '—'; }, num: true },
          { h: 'See live example', v: function (r) { return r.liveExample ? n(r.liveExample) : '—'; }, num: true },
        ], f.offerClicks || [], 'Nobody has clicked either button in this range.'));

      // The answer to "are those pitch readers bots, humans, or me?" — one row
      // per person, with the location and network that identify them.
      var readers = f.pitchReaders || [];
      html += card('Who read the pitch',
        readers.length
          ? n(readers.length) + ' real ' + (readers.length === 1 ? 'person' : 'people') + ' reached /get-started'
          : 'Nobody reached /get-started in this range',
        table([
          { h: 'Location', v: function (r) { return r.location || 'Unknown'; } },
          { h: 'Network', v: function (r) { return r.org || '—'; } },
          { h: 'Device', v: function (r) { return r.mobile ? 'Mobile' : 'Desktop'; } },
          { h: 'Came from', v: function (r) { return r.cameFromPlayerPage ? 'A player page' : (r.referrer ? 'Elsewhere' : 'Direct'); } },
          { h: 'Visits', v: function (r) { return n(r.visits); }, num: true },
          { h: 'Then', v: function (r) {
              var acts = [];
              if (r.clickedExample) acts.push('saw the example');
              if (r.submitted) acts.push('REQUESTED');
              return acts.length ? acts.join(', ') : '—';
            } },
          { h: 'Last seen', raw: true, v: function (r) {
              return '<span title="' + esc(r.displayTime || '') + '">' + esc(ago(r.lastSeen)) + '</span>'; } },
        ], readers, 'No one yet.'),
        disclosure('How do I know these are real people?',
          '<div class="db-note">' +
          '<p style="margin-bottom:10px">Three filters run before anyone appears here. <strong>Network:</strong> datacenter and cloud addresses are dropped. <strong>Browser:</strong> anything announcing itself as a crawler is dropped — this is the one that matters most, because Applebot runs from Apple&rsquo;s own network and its visits look like a person on a Mac until you read the user agent. <strong>Location:</strong> your own visits (North York) are dropped.</p>' +
          '<p>Each row is one address, so the same person on the same connection is one row no matter how many times they came back — the visit count tells you that. Two people in the same house share a row; one person switching from wifi to mobile data becomes two.</p>' +
          '</div>'));

      // ── 4. Audience ──
      html += section('Audience', 'who is actually showing up');
      var conf = f.confirmed || { people: 0, of: 0 };
      // Naming: the "Visits" tile is the audience block's `arrivals` (sessions
      // that started from outside the site); "Page views" is `pageviews` (every
      // load). The backend keeps the old key names — this is a display relabel.
      html += '<div class="db-kpis">' +
        kpi('People', compact(a.people), delta(a.delta.people, true), 'Bots and your own visits excluded.') +
        kpi('Confirmed human', compact(conf.people), '',
          'Of those, the ones who clicked something or read more than one page — a floor you can trust.') +
        kpi('Visits', compact(a.arrivals), delta(a.delta.arrivals, true), 'A session — one time someone showed up from outside the site.') +
        kpi('Page views', compact(a.pageviews), delta(a.delta.pageviews, true), 'Every page load, including clicking around inside the site.') +
        kpi('Pages per visit', (a.engagement.pagesPerArrival || 0).toFixed(1), '', 'How deep people browse once they arrive.') +
        '</div>';

      html += card('Traffic over time', 'Visits is the number to watch — page views rise just from people clicking around.',
        trendChart(a.byDay));

      var groups = (a.sourceGroups || []).map(function (g) {
        return { label: g.group, count: g.count, share: g.share };
      });
      html += card('Where visitors are from',
        (a.geo || []).length + ' countries · hover a bubble for the cities inside it',
        geoMap(a.geo) +
        barList((a.geo || []).slice(0, 8).map(function (g) {
          return { label: g.country, count: g.people, share: g.share };
        }), { empty: 'No location data in this range.' }),
        disclosure('Every country, with cities',
          table([
            { h: 'Country', v: function (g) { return g.country; } },
            { h: 'People', v: function (g) { return n(g.people); }, num: true },
            { h: 'Share', v: function (g) { return pct(g.share, 1); }, num: true },
            { h: 'Cities', v: function (g) { return g.cities.map(function (c) { return c.city + ' (' + c.people + ')'; }).join(', ') || '—'; } },
          ], a.geo || [], 'No location data.')));

      html += card('Where visits come from',
        'Grouped by kind, counted from <strong>visits only</strong> — clicks between pages of your own site are browsing, not a traffic source, so they are not in this list.',
        barList(groups, { empty: 'No visits in this range.' }),
        disclosure('Break down by exact site',
          barList((a.sourceHosts || []).map(function (h) { return { label: h.host, count: h.count }; }),
            { empty: 'No referring sites yet — all visits were direct.' }) +
          '<div class="db-note" style="margin-top:14px"><strong>Direct</strong> (' + n(a.direct) + ') means no referrer was sent: typed the URL, a bookmark, a link from an app, or a browser that strips referrers.</div>')
      );

      // ── 5. What's pulling the traffic ──
      // The headline list is every page; the per-type breakdowns (teams,
      // comparisons, shares) sit behind disclosures — real detail, but not
      // what you open the dashboard to find out.
      var c = data.content || {};
      var pl = c.player || { views: 0, top: [] }, tm = c.team || { views: 0, top: [] };
      var cm = c.compare || { views: 0, top: [], topPlayers: [] }, sh = c.shares || { total: 0, top: [], recent: [] };
      function pageBars(rows) {
        return barList((rows || []).map(function (r) {
          return { label: r.title || r.page, count: r.count };
        }), { empty: 'Nothing in this range.' });
      }

      html += section('Content', 'what people are looking at');
      html += card('Most-viewed pages', 'Player pages are the ones that carry the offer.',
        barList((a.topPages || []).slice(0, 10).map(function (p) {
          return { label: p.title || p.page, count: p.count };
        }), { empty: 'No page views in this range.' }),
        disclosure('Break down by page type',
          '<div class="db-note" style="margin-bottom:14px">' +
            n(pl.views) + ' player-page views from ' + n(pl.people) + ' people · ' +
            n(tm.views) + ' team-page views · ' + n(cm.views) + ' comparisons</div>' +
          '<div style="font-size:11.5px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.4px;margin-bottom:8px">Players</div>' +
          pageBars(pl.top) +
          '<div style="font-size:11.5px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.4px;margin:18px 0 8px">Teams</div>' +
          pageBars(tm.top) +
          '<div style="font-size:11.5px;font-weight:700;color:var(--text-2);text-transform:uppercase;letter-spacing:.4px;margin:18px 0 8px">Most-compared players</div>' +
          barList((cm.topPlayers || []).map(function (r) { return { label: r.name, count: r.count }; }),
            { empty: 'No comparisons in this range.' }) +
          '<div class="db-note" style="margin-top:8px">A view of “A vs B” counts once for each player, so these add up to about twice the comparison views.</div>'));

      html += card('Shares', n(sh.total) + ' ' + (sh.total === 1 ? 'share' : 'shares') + ' ' + rangeWord,
        pageBars(sh.top),
        disclosure('Recent shares',
          table([
            { h: 'When', raw: true, v: function (r) {
              return '<span title="' + esc(r.displayTime || '') + '">' + esc(ago(r.sharedAt)) + '</span>'; } },
            { h: 'Page', v: function (r) { return r.title || r.page || '—'; } },
            { h: 'How', v: function (r) { return r.method === 'native' ? 'Share sheet' : 'Copied link'; } },
          ], sh.recent, 'No shares in this range.')));

      // ── 6. Leads ──
      html += section('Leads', 'the actual people who asked');
      html += '<div class="db-leads">' + card('Website requests', n(f.leads.count) + ' ' + rangeWord,
        table([
          { h: 'Player', v: function (r) { return r.playerName || '—'; } },
          { h: 'Contact', v: function (r) { return r.parentName || '—'; } },
          { h: 'Email', v: function (r) { return r.email || '—'; } },
          { h: 'Phone', v: function (r) { return r.phone || '—'; } },
          { h: 'When', raw: true, v: function (r) {
              return '<span title="' + esc(r.createdAt ? new Date(r.createdAt).toLocaleString() : '') + '">' + esc(ago(r.createdAt)) + '</span>'; } },
        ], f.leads.recent, 'No requests in this range yet.')) + '</div>';

      // ── 7. Data quality — always available, never in a headline ──
      html += card('How these numbers are counted', null,
        '<div class="db-pills">' +
          '<span class="db-pill">' + n(a.excluded.bots) + ' bot page views excluded</span>' +
          '<span class="db-pill">' + n(a.excluded.owner) + ' of your own visits excluded</span>' +
          '<span class="db-pill">' + n(a.engagement.internalPageviews) + ' internal page-to-page clicks</span>' +
        '</div>' +
        '<div class="db-note">Everything above this card counts humans only. Bots are still recorded in the database — they are just never shown in a headline number.</div>',
        disclosure('The full definitions',
          '<div class="db-note">' +
          '<p style="margin-bottom:10px"><strong>Bots</strong> are caught two ways. <em>Network:</em> datacenter and cloud providers (AWS, Google Cloud, Azure, Cloudflare). <em>Browser:</em> anything announcing itself as a crawler in its user agent — Applebot, Googlebot, headless Chrome and the rest. The second check matters most: Applebot runs from Apple&rsquo;s own network, so it looks like a person on a Mac until you read the user agent.</p>' +
          '<p style="margin-bottom:10px"><strong>This can only ever be a ceiling.</strong> A crawler that sends an ordinary Chrome user agent from a home broadband address is indistinguishable from a person at this level. That is why <strong>Confirmed human</strong> exists beside it: it counts only visitors who clicked something or read more than one page, which crawlers essentially never do. The true number sits between the two.</p>' +
          '<p style="margin-bottom:10px"><strong>Your own visits</strong> are excluded by address and subnet, not city. Your ISP moves you around inside a block and geolocation resolves the same house to different cities on different days — matching on &ldquo;North York&rdquo; alone let one of your own clicks through as a customer.</p>' +
          '<p style="margin-bottom:10px"><strong>Proven yours</strong> (' + n((a.excluded.ownerProven || []).length) + ') — these addresses were seen geolocating to North York: <code>' +
          esc((a.excluded.ownerProven || []).join(', ') || 'none') + '</code></p>' +
          '<p style="margin-bottom:10px"><strong>Inferred</strong> (' + n((a.excluded.ownerInferred || []).length) + ') — excluded only because they share an ISP block with a proven address: <code>' +
          esc((a.excluded.ownerInferred || []).join(', ') || 'none') + '</code>. This is inference, not proof: a /24 is 256 addresses and on a large ISP it can cover more than one household. It is on because the alternative lets your own traffic back in every time your ISP reassigns you, which distorts the numbers more. Set <code>OWNER_SUBNET_MATCH=off</code> for exact addresses only, or add addresses by hand with <code>OWNER_IPS</code>.</p>' +
          '<p style="margin-bottom:10px"><strong>Internal page-to-page clicks</strong> are page views whose referrer was circuitstats.com itself. They count toward page views but never toward visits, and are never listed as a traffic source — that was making browsing look like a source of traffic.</p>' +
          '<p><strong>Visits vs page views:</strong> one person reading eight player pages is 1 person, 1 visit and 8 page views. A “visit” is a session that started from outside the site; a “page view” is any single load. Leading with the 8 would overstate reach and make every conversion rate look ~8x worse than it is — so Visits is the headline, not the raw page-view count.</p>' +
          '</div>')
      );

      el('db-content').innerHTML = html;
      el('db-content').classList.remove('db-loading');
      wireTrend(a.byDay);
      wireGeo();
      animate();
    }

    // ── Load ─────────────────────────────────────────────────────────────────
    var inflight = 0;
    async function load() {
      var token = localStorage.getItem('cb_token');
      if (!token) {
        el('db-content').textContent = 'Sign in with the owner account to view analytics.';
        if (window.gateOpen) window.gateOpen();
        return;
      }
      var mine = ++inflight;
      var content = el('db-content');
      // Hold the previous render at reduced opacity rather than flashing a
      // skeleton — no layout jump when switching range.
      if (content.innerHTML && !content.classList.contains('db-loading')) content.style.opacity = '.45';
      else content.textContent = 'Loading…';

      try {
        var res = await fetch(API + '/dashboard/overview?days=' + days, {
          headers: { Authorization: 'Bearer ' + token },
        });
        if (mine !== inflight) return;             // a newer range won the race
        if (res.status === 403) { content.textContent = 'Owner access only.'; content.style.opacity = '1'; return; }
        if (!res.ok) throw new Error('HTTP ' + res.status);
        render(await res.json());
        content.style.opacity = '1';
      } catch (e) {
        if (mine !== inflight) return;
        content.style.opacity = '1';
        content.classList.add('db-loading');
        content.textContent = 'Could not load analytics: ' + e.message;
      }
    }

    document.querySelectorAll('.db-range').forEach(function (b) {
      b.addEventListener('click', function () {
        document.querySelectorAll('.db-range').forEach(function (x) { x.classList.remove('is-on'); });
        b.classList.add('is-on');
        days = b.getAttribute('data-days') || '30';
        el('db-range-label').textContent = days === 'all' ? 'Since launch' : 'Last ' + days + ' days';
        load();
      });
    });

    window.onGateUnlock = load;
    if (new URLSearchParams(location.search).has('auth')) {
      el('db-content').textContent = 'Signing you in…';
    } else {
      load();
    }
  })();
</script>
