    // ── The funnel ───────────────────────────────────────────────────────────
    // Centred bars so the silhouette narrows like a funnel, each stage direct-
    // labelled with its absolute count and step conversion (so a tiny tail bar
    // is still fully readable), and the drop between stages named in the gap.
    function funnelHtml(f) {
      var stages = f.stages || [];
      var top = stages.length ? stages[0].people : 0;
      var leakKey = f.leak && f.leak.key;

      return '<div class="db-funnel">' + stages.map(function (s, i) {
        var w = top ? Math.max(2.5, (s.people / top) * 100) : 2.5;
        var color = FUNNEL_COLORS[Math.min(i, FUNNEL_COLORS.length - 1)];
        var isLight = i >= LIGHT_FILL_FROM;
        // Only put the label inside the bar when it comfortably fits; below
        // ~22% width it would be clipped, so it lives in the right-hand column
        // (which always shows it anyway).
        var inside = w > 22 ? '<span>' + pct(s.totalRate, 1) + ' of all visitors</span>' : '';
        var drop = '';
        if (i > 0 && s.dropped > 0) {
          var isLeak = leakKey === s.key;
          drop = '<div class="db-drop' + (isLeak ? ' is-leak' : '') + '">' +
            n(s.dropped) + ' dropped off here' +
            (isLeak ? ' — biggest leak' : '') + '</div>';
        }
        return drop +
          '<div class="db-stage"><div class="db-stage-row" tabindex="0" title="' + esc(s.hint || '') + '">' +
            '<div class="db-stage-nm"><div class="db-stage-name">' + esc(s.label) + '</div>' +
              (s.hint ? '<div class="db-stage-hint">' + esc(s.hint) + '</div>' : '') + '</div>' +
            '<div class="db-stage-track">' +
              '<div class="db-stage-bar' + (isLight ? '' : ' is-dark') + '" data-w="' + w.toFixed(2) + '" style="background:' + color + '">' + inside + '</div>' +
            '</div>' +
            '<div class="db-stage-val">' +
              '<div class="db-stage-people">' + n(s.people) + '</div>' +
              '<div class="db-stage-pct">' + (i === 0 ? 'people' : pct(s.stepRate, 1) + ' of prev') + '</div>' +
            '</div>' +
          '</div></div>';
      }).join('') + '</div>';
    }

