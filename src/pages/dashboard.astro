---
// /dashboard — owner analytics.
//
// Rebuilt around one question: is the recruiting-website offer working?
// The old version led with raw visit counts (which double-counted internal
// page-to-page navigation and mixed bot-inclusive "Unique IPs" next to
// bot-excluded "Human Visits"), and never showed the funnel at all — every CTA
// click was written to Mongo and displayed nowhere.
//
// Shape now: verdict → funnel → audience → detail, with everything below the
// funnel collapsed by default. One range filter scopes the whole page, and one
// request (/dashboard/overview) serves it, so every number reconciles.
//
// Client-rendered after auth: GateModal (in Layout) redeems a magic link /
// stored token, then render() fetches the backend. noindex.
import Layout from '../layouts/Layout.astro';
const SITE = 'https://www.circuitstats.com';
---
<Layout
  title="Dashboard | Circuit Stats"
  subLabel="Owner analytics"
  pillLabel="ALL"
  pageBase="/rankings"
  activeTab={null}
  canonical={`${SITE}/dashboard`}
  robots="noindex,nofollow"
>
  <div class="db">
    <div class="db-head">
      <div>
        <h1 class="db-title">Dashboard</h1>
        <p class="db-sub" id="db-range-label">Last 30 days</p>
      </div>
      <div class="db-ranges" role="group" aria-label="Date range">
        <button class="db-range" data-days="7">7d</button>
        <button class="db-range is-on" data-days="30">30d</button>
        <button class="db-range" data-days="90">90d</button>
        <button class="db-range" data-days="all">All time</button>
      </div>
    </div>
    <div id="db-content" class="db-loading">Loading…</div>
  </div>
</Layout>

<style is:global>
  /* Scoped under .db — Astro's scoped styles don't reach innerHTML-injected
     nodes, and this page builds its entire body in JS. */
  .db { max-width: 1080px; margin: 0 auto; padding: 16px 16px 56px; }

  /* ── Chart tokens ──────────────────────────────────────────────────────────
     A blue ordinal ramp for the funnel (ordered stages) and the accent for
     single-series magnitude bars. Validated with the dataviz palette checker
     against this page's card surface (#12182a): monotone lightness, all
     adjacent gaps >= 0.06 L, light end clears 2:1, hue spread 4 degrees.
     The funnel runs dark -> light down the stages so the narrow end (the money)
     is the brightest thing on a dark surface. */
  .db {
    --f1: #184f95; --f2: #256abf; --f3: #3987e5;
    --f4: #6da7ec; --f5: #9ec5f4; --f6: #cde2fb;
    --grid: #1c2b44;
    /* Map land sits just above the card surface — present enough to read as
       continents, quiet enough that the data bubbles stay the loudest thing. */
    --map-land: #1b2740;
    --map-edge: #2a3c5e;
    --ink-mute: #7f93b5;
    --good: #34d399;
    --bad: #f87171;
  }

  .db-head {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 16px; flex-wrap: wrap; margin-bottom: 22px;
  }
  .db-title { font-size: 26px; font-weight: 900; letter-spacing: -.6px; line-height: 1.1; }
  .db-sub { font-size: 13px; color: var(--text-2); margin-top: 3px; }
  .db-loading { color: var(--text-2); font-size: 13px; padding: 40px 0; text-align: center; }

  .db-ranges { display: flex; gap: 4px; background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 3px; }
  .db-range {
    border: none; background: none; color: var(--text-2);
    font-size: 12.5px; font-weight: 700; padding: 6px 13px; border-radius: 7px;
    transition: background .14s, color .14s;
  }
  .db-range:hover { color: var(--text); }
  .db-range.is-on { background: var(--accent); color: #fff; }

  /* ── Verdict: the one thing to read first ──────────────────────────────── */
  .db-verdict {
    background: linear-gradient(150deg, rgba(79,142,247,.10), transparent 60%), var(--card);
    border: 1px solid var(--border); border-radius: 16px;
    padding: 22px 22px 20px; margin-bottom: 18px;
    display: grid; grid-template-columns: auto 1fr; gap: 26px; align-items: center;
  }
  .db-hero-n {
    font-size: 60px; font-weight: 800; line-height: .9; letter-spacing: -2.5px;
    /* proportional figures: tabular-nums makes a display-size number look loose */
  }
  .db-hero-l { font-size: 12.5px; color: var(--text-2); margin-top: 7px; font-weight: 600; }
  .db-verdict-txt { font-size: 15px; line-height: 1.6; color: var(--text); }
  .db-verdict-txt strong { color: var(--accent); font-weight: 800; }
  .db-verdict-txt .lo { color: var(--bad); font-weight: 800; }
  .db-verdict-sub { font-size: 12.5px; color: var(--text-2); margin-top: 8px; line-height: 1.55; }

  /* ── Cards ─────────────────────────────────────────────────────────────── */
  .db-card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: 16px; margin-bottom: 18px; overflow: hidden;
  }
  .db-card-h { padding: 16px 20px 0; }
  .db-card-t { font-size: 15px; font-weight: 800; letter-spacing: -.2px; }
  .db-card-s { font-size: 12.5px; color: var(--text-2); margin-top: 3px; line-height: 1.5; }
  .db-card-b { padding: 18px 20px 20px; }

  /* ── Stat tiles ────────────────────────────────────────────────────────── */
  .db-kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-bottom: 18px; }
  .db-kpi { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 15px 16px; }
  .db-kpi-l { font-size: 11.5px; color: var(--text-2); font-weight: 600; display: flex; align-items: center; gap: 5px; }
  .db-kpi-v { font-size: 30px; font-weight: 800; letter-spacing: -1px; margin-top: 6px; line-height: 1; }
  .db-kpi-d { font-size: 11.5px; font-weight: 700; margin-top: 6px; display: flex; align-items: center; gap: 4px; }
  .db-kpi-d.up { color: var(--good); }
  .db-kpi-d.down { color: var(--bad); }
  .db-kpi-d.flat { color: var(--text-3); }
  .db-kpi-note { font-size: 11px; color: var(--text-3); margin-top: 5px; line-height: 1.45; }

  /* ── Funnel ────────────────────────────────────────────────────────────── */
  .db-funnel { padding: 4px 0 0; }
  .db-stage { margin-bottom: 2px; }
  .db-stage-row {
    display: grid; grid-template-columns: 1fr minmax(0, 2.2fr) auto;
    align-items: center; gap: 14px;
    padding: 9px 0; border-radius: 10px;
    transition: background .14s;
  }
  .db-stage-row:hover, .db-stage-row:focus-visible { background: rgba(79,142,247,.07); outline: none; }
  .db-stage-name { font-size: 13.5px; font-weight: 700; }
  .db-stage-hint { font-size: 11.5px; color: var(--text-3); margin-top: 2px; line-height: 1.4; }
  .db-stage-track { display: flex; justify-content: center; }
  .db-stage-bar {
    height: 30px; border-radius: 5px; min-width: 3px;
    width: 0; transition: width .75s cubic-bezier(.22,.9,.3,1);
    display: flex; align-items: center; justify-content: center;
  }
  .db-stage-bar span { font-size: 12px; font-weight: 800; color: rgba(0,0,0,.62); padding: 0 8px; white-space: nowrap; }
  .db-stage-bar.is-dark span { color: rgba(255,255,255,.92); }
  .db-stage-val { text-align: right; min-width: 74px; }
  .db-stage-people { font-size: 17px; font-weight: 800; letter-spacing: -.3px; }
  .db-stage-pct { font-size: 11.5px; color: var(--text-2); font-weight: 600; margin-top: 1px; }
  .db-drop {
    display: flex; align-items: center; gap: 7px;
    font-size: 11.5px; color: var(--text-3);
    padding: 3px 0 3px 0; margin-left: 2px;
  }
  .db-drop::before {
    content: ''; width: 1px; height: 16px; background: var(--grid); margin-left: 8px; flex-shrink: 0;
  }
  .db-drop.is-leak { color: var(--bad); font-weight: 700; }


  /* ── Geography ─────────────────────────────────────────────────────────── */
  .geo-wrap { position: relative; width: 100%; }
  .geo-wrap svg { display: block; width: 100%; height: auto; overflow: visible; }
  .geo-b { cursor: pointer; }
  .geo-b circle:first-child { transition: fill-opacity .12s; }
  .geo-b:hover circle:first-child, .geo-b:focus circle:first-child { fill-opacity: .55; }
  .db-tip-c { font-size: 11px; color: var(--text-2); margin-top: 5px; line-height: 1.45; white-space: normal; }
  .db-tip { max-width: 250px; }

  /* ── Charts ────────────────────────────────────────────────────────────── */
  .db-chart { position: relative; width: 100%; }
  .db-chart svg { display: block; width: 100%; height: 128px; overflow: visible; }

  /* Small multiples: two single-series panels sharing an x-axis. */
  .db-trends { position: relative; display: flex; flex-direction: column; gap: 4px; }
  .db-panel-h { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; padding: 0 0 2px 38px; }
  .db-panel-t { font-size: 11.5px; font-weight: 700; color: var(--text-2); letter-spacing: .2px; }
  .db-panel-v { font-size: 12.5px; font-weight: 800; color: var(--text); font-variant-numeric: tabular-nums; }
  /* Transparent hover layer aligned to the plot area of both panels. */
  .db-hitwrap { position: absolute; left: 38px; right: 10px; top: 0; bottom: 22px; cursor: crosshair; }
  .db-tip {
    position: absolute; pointer-events: none; opacity: 0;
    background: var(--surface); border: 1px solid var(--border); border-radius: 9px;
    padding: 8px 11px; font-size: 12px; white-space: nowrap; z-index: 40;
    box-shadow: 0 8px 26px rgba(0,0,0,.55); transition: opacity .1s;
  }
  .db-tip-d { font-size: 10.5px; color: var(--text-3); margin-bottom: 4px; font-weight: 600; }
  .db-tip-r { display: flex; align-items: center; gap: 7px; line-height: 1.7; }
  .db-tip-k { width: 11px; height: 2px; border-radius: 2px; flex-shrink: 0; }
  .db-tip-v { font-weight: 800; color: var(--text); font-variant-numeric: tabular-nums; }
  .db-tip-n { color: var(--text-2); font-size: 11.5px; }
  .db-legend { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 12px; }
  .db-leg { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-2); }
  .db-leg i { width: 13px; height: 2.5px; border-radius: 2px; display: block; }
  .db-leg i.sq { height: 11px; width: 11px; border-radius: 3px; }

  /* ── Bar list (single-series magnitude) ────────────────────────────────── */
  .db-bars { display: flex; flex-direction: column; gap: 9px; }
  .db-bar-row { display: grid; grid-template-columns: minmax(84px, 132px) 1fr auto; align-items: center; gap: 11px; }
  .db-bar-l { font-size: 12.5px; font-weight: 600; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .db-bar-t { background: rgba(255,255,255,.04); border-radius: 4px; height: 15px; overflow: hidden; }
  .db-bar-f { height: 100%; background: var(--accent); border-radius: 4px; width: 0; transition: width .6s cubic-bezier(.22,.9,.3,1); }
  .db-bar-v { font-size: 12.5px; font-weight: 800; min-width: 58px; text-align: right; font-variant-numeric: tabular-nums; }
  .db-bar-v small { color: var(--text-3); font-weight: 600; font-size: 11px; margin-left: 3px; }

  /* ── Tables ────────────────────────────────────────────────────────────── */
  .db-tw { overflow-x: auto; margin: 0 -20px; padding: 0 20px; }
  .db-t { width: 100%; border-collapse: collapse; font-size: 12.5px; }
  .db-t th {
    text-align: left; font-size: 10.5px; font-weight: 700; color: var(--text-3);
    text-transform: uppercase; letter-spacing: .5px; padding: 0 12px 8px 0; white-space: nowrap;
  }
  .db-t td { padding: 9px 12px 9px 0; border-top: 1px solid var(--border); color: var(--text-2); vertical-align: top; }
  .db-t td.k { color: var(--text); font-weight: 600; }
  .db-t tr:hover td { color: var(--text); }
  .db-t .num { font-variant-numeric: tabular-nums; }

  /* ── Disclosure ────────────────────────────────────────────────────────── */
  .db-more { border-top: 1px solid var(--border); }
  .db-more > summary {
    list-style: none; cursor: pointer; padding: 13px 20px;
    font-size: 12.5px; font-weight: 700; color: var(--accent);
    display: flex; align-items: center; gap: 7px; user-select: none;
  }
  .db-more > summary::-webkit-details-marker { display: none; }
  .db-more > summary::after {
    content: ''; width: 6px; height: 6px; flex-shrink: 0;
    border-right: 1.8px solid currentColor; border-bottom: 1.8px solid currentColor;
    transform: rotate(45deg) translateY(-2px); transition: transform .18s;
  }
  .db-more[open] > summary::after { transform: rotate(-135deg) translateY(-1px); }
  .db-more > summary:hover { background: rgba(79,142,247,.06); }
  .db-more-b { padding: 4px 20px 20px; }

  .db-sec { display: flex; align-items: baseline; gap: 9px; margin: 30px 0 13px; }
  .db-sec h2 { font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.1px; color: var(--text-3); }
  .db-sec p { font-size: 12px; color: var(--text-3); }

  .db-empty { font-size: 12.5px; color: var(--text-3); padding: 6px 0; }
  .db-note { font-size: 12px; color: var(--text-3); line-height: 1.6; }
  .db-note strong { color: var(--text-2); }
  .db-note code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 11.5px; color: var(--text-2); }

  .db-pills { display: flex; gap: 7px; flex-wrap: wrap; margin-bottom: 14px; }
  .db-pill { font-size: 11.5px; font-weight: 700; padding: 4px 10px; border-radius: 20px; background: rgba(255,255,255,.05); color: var(--text-2); }

  /* ── Responsive ────────────────────────────────────────────────────────── */
  @media (max-width: 720px) {
    .db { padding: 14px 13px 48px; }
    .db-verdict { grid-template-columns: 1fr; gap: 16px; padding: 18px; }
    .db-hero-n { font-size: 48px; letter-spacing: -1.8px; }
    .db-title { font-size: 22px; }
    .db-kpis { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .db-kpi-v { font-size: 25px; }
    .db-card-h { padding: 15px 16px 0; }
    .db-card-b { padding: 15px 16px 17px; }
    .db-more > summary, .db-more-b { padding-left: 16px; padding-right: 16px; }
    .db-tw { margin: 0 -16px; padding: 0 16px; }
    /* Funnel drops the hint and stacks the bar under the label so it keeps
       usable width on a phone instead of squeezing to a nub. Explicit row/column
       placement: with auto-placement the full-width bar pushes the value onto a
       third row, detaching it from the stage it belongs to. */
    .db-stage-row { grid-template-columns: 1fr auto; gap: 6px 12px; align-items: baseline; }
    .db-stage-nm { grid-column: 1; grid-row: 1; }
    .db-stage-val { grid-column: 2; grid-row: 1; text-align: right; min-width: 0; }
    .db-stage-track { grid-column: 1 / -1; grid-row: 2; justify-content: flex-start; }
    .db-stage-bar { height: 24px; }
    .db-stage-hint { display: none; }
    /* Count and rate share one line on mobile to keep each stage compact. */
    .db-stage-people { display: inline; font-size: 16px; }
    .db-stage-pct { display: inline; margin-left: 6px; }
    .db-bar-row { grid-template-columns: minmax(72px, 104px) 1fr auto; gap: 9px; }
    /* Taller panels on a phone: at 390px wide the desktop aspect ratio would
       squash each plot to ~60px and the shape would be unreadable. */
    .db-chart svg { height: 150px; }
    .db-hitwrap { bottom: 26px; }

    /* The leads table has five columns and no useful way to shrink — turn each
       row into a stacked card instead of a 5-way horizontal squeeze. */
    .db-leads .db-t, .db-leads .db-t tbody, .db-leads .db-t tr, .db-leads .db-t td { display: block; width: 100%; }
    .db-leads .db-t thead { display: none; }
    .db-leads .db-t tr { border-top: 1px solid var(--border); padding: 12px 0 4px; }
    .db-leads .db-t td { border: none; padding: 1px 0; }
    .db-leads .db-t td::before {
      content: attr(data-l) ' '; color: var(--text-3); font-size: 11px;
      text-transform: uppercase; letter-spacing: .4px; font-weight: 700;
    }
    .db-leads .db-t td.k { font-size: 14.5px; font-weight: 800; color: var(--text); padding-bottom: 4px; }
    .db-leads .db-t td.k::before { display: none; }
    .db-leads .db-tw { overflow-x: visible; }
  }
  @media (prefers-reduced-motion: reduce) {
    .db-stage-bar, .db-bar-f { transition: none; }
  }
</style>

<script is:inline>
  (function () {
    var API = (location.hostname === 'localhost' || location.hostname === '127.0.0.1')
      ? 'http://localhost:4000/a1a2-command-center' : '/a1a2-command-center';

    var FUNNEL_COLORS = ['var(--f1)', 'var(--f2)', 'var(--f3)', 'var(--f4)', 'var(--f5)', 'var(--f6)'];
    // Which stage fills need dark text on top of them (the light end of the ramp).
    var LIGHT_FILL_FROM = 3;

    var days = '30';
    var el = function (id) { return document.getElementById(id); };

    // ── helpers ──────────────────────────────────────────────────────────────
    function esc(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }
    function n(v) { return (v == null ? 0 : v).toLocaleString('en-US'); }
    function compact(v) {
      v = v || 0;
      if (v >= 1e6) return (v / 1e6).toFixed(v >= 1e7 ? 0 : 1).replace(/\.0$/, '') + 'M';
      if (v >= 1e4) return (v / 1e3).toFixed(0) + 'K';
      return v.toLocaleString('en-US');
    }
    function pct(x, dp) {
      if (x == null) return '—';
      var v = x * 100;
      return (v < 1 && v > 0 ? v.toFixed(dp == null ? 2 : dp) : v.toFixed(v < 10 ? 1 : 0)) + '%';
    }
    // "3m" / "3h" / "3d 3h" — how long ago, which is what you actually want from
    // a log. An absolute timestamp makes you do the subtraction in your head.
    function ago(ts) {
      if (!ts) return '—';
      var then = new Date(ts).getTime();
      if (!then) return '—';
      var s = Math.max(0, (Date.now() - then) / 1000);
      if (s < 60) return 'just now';
      var m = Math.floor(s / 60);
      if (m < 60) return m + 'm';
      var h = Math.floor(m / 60);
      if (h < 24) return h + 'h';
      var d = Math.floor(h / 24), rh = h % 24;
      if (d < 30) return d + 'd' + (rh ? ' ' + rh + 'h' : '');
      var mo = Math.floor(d / 30);
      return mo + 'mo' + (d % 30 ? ' ' + (d % 30) + 'd' : '');
    }
    function shortDate(iso) {
      var p = String(iso).split('-');
      return p.length === 3 ? (+p[1]) + '/' + (+p[2]) : iso;
    }
    function longDate(iso) {
      var d = new Date(iso + 'T12:00:00');
      return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
    }

    // Delta chip. `goodUp` lets a metric where down-is-good render correctly.
    function delta(d, goodUp) {
      if (d == null) return '<div class="db-kpi-d flat">no prior period</div>';
      if (d === 0) return '<div class="db-kpi-d flat">no change</div>';
      var up = d > 0;
      var cls = (up === (goodUp !== false)) ? 'up' : 'down';
      return '<div class="db-kpi-d ' + cls + '">' + (up ? '▲' : '▼') + ' ' +
        Math.abs(d).toFixed(Math.abs(d) < 10 ? 1 : 0) + '% <span style="color:var(--text-3);font-weight:600">vs prev ' + days + 'd</span></div>';
    }

    function kpi(label, value, deltaHtml, note) {
      return '<div class="db-kpi">' +
        '<div class="db-kpi-l">' + esc(label) + '</div>' +
        '<div class="db-kpi-v">' + value + '</div>' +
        (deltaHtml || '') +
        (note ? '<div class="db-kpi-note">' + note + '</div>' : '') +
        '</div>';
    }

    function card(title, sub, body, more) {
      return '<div class="db-card">' +
        '<div class="db-card-h"><div class="db-card-t">' + title + '</div>' +
        (sub ? '<div class="db-card-s">' + sub + '</div>' : '') + '</div>' +
        '<div class="db-card-b">' + body + '</div>' +
        (more || '') + '</div>';
    }
    function disclosure(label, body) {
      return '<details class="db-more"><summary>' + esc(label) + '</summary>' +
        '<div class="db-more-b">' + body + '</div></details>';
    }
    function section(title, note) {
      return '<div class="db-sec"><h2>' + esc(title) + '</h2>' + (note ? '<p>' + esc(note) + '</p>' : '') + '</div>';
    }

    // Single-series magnitude bars: one colour for every bar (the length is the
    // encoding; colouring by rank would double-encode it).
    function barList(items, opts) {
      opts = opts || {};
      if (!items || !items.length) return '<div class="db-empty">' + (opts.empty || 'Nothing yet.') + '</div>';
      var max = items.reduce(function (m, it) { return Math.max(m, it.count || 0); }, 0) || 1;
      return '<div class="db-bars">' + items.map(function (it) {
        var w = Math.max(1.5, ((it.count || 0) / max) * 100);
        return '<div class="db-bar-row">' +
          '<div class="db-bar-l" title="' + esc(it.label) + '">' + esc(it.label) + '</div>' +
          '<div class="db-bar-t"><div class="db-bar-f" data-w="' + w.toFixed(2) + '"></div></div>' +
          '<div class="db-bar-v">' + n(it.count) +
            (it.share != null ? '<small>' + pct(it.share, 1) + '</small>' : '') +
          '</div></div>';
      }).join('') + '</div>';
    }

    function table(cols, rows, empty) {
      if (!rows || !rows.length) return '<div class="db-empty">' + (empty || 'Nothing yet.') + '</div>';
      return '<div class="db-tw"><table class="db-t"><thead><tr>' +
        cols.map(function (c) { return '<th>' + esc(c.h) + '</th>'; }).join('') +
        '</tr></thead><tbody>' +
        rows.map(function (r) {
          return '<tr>' + cols.map(function (c, i) {
            var v = c.v(r);
            // data-l lets the mobile stylesheet re-label each cell once the
            // table collapses into stacked cards and the header row is hidden.
