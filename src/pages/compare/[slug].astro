---
// /compare/<a>-vs-<b> — head-to-head page for ANY two players. Server-rendered
// (prerender=false) so every pair a visitor can pick resolves to a real URL with
// real HTML (crawlable, shareable) — no pre-building millions of pairs. Renders
// the exact pre-SEO compare view with both slots filled.
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import Compare from '../../components/Compare.astro';
import { refBySlug } from '../../lib/slugs';
import { byKey } from '../../lib/leagues';

const slug = Astro.params.slug || '';
const parts = slug.split('-vs-');
const SITE = 'https://www.circuitstats.com';

let a = null, b = null, league = null;
if (parts.length === 2) {
  const ra = refBySlug(parts[0]);
  const rb = refBySlug(parts[1]);
  if (ra && rb) { a = ra.player; b = rb.player; league = ra.league; }
}
if (!a || !b || !league) {
  // Explicit Content-Type so this renders as a page instead of some browsers
  // (seen on iOS Safari) offering the bare-text response as a .txt download.
  return new Response(
    `<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8" />` +
    `<meta name="viewport" content="width=device-width, initial-scale=1.0" />` +
    `<title>Comparison not found | Circuit Stats</title><meta name="robots" content="noindex" />` +
    `<style>body{background:#08090f;color:#eef2ff;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;` +
    `display:flex;align-items:center;justify-content:center;min-height:100vh;margin:0;text-align:center;padding:24px}` +
    `a{color:#4f8ef7;font-weight:700;text-decoration:none}h1{font-size:20px;margin:0 0 10px}p{color:#7f93b5;font-size:14px;margin:0 0 20px}</style>` +
    `</head><body><div><h1>Comparison not found</h1><p>That match-up doesn't exist or the link is broken.</p><a href="/">Back to Circuit Stats</a></div></body></html>`,
    { status: 404, headers: { 'Content-Type': 'text/html; charset=utf-8' } }
  );
}
// Keep showing whatever scope the visitor was actually browsing (passed through
// by Compare.astro's picker) instead of always falling back to player A's own
// base league — e.g. comparing from a combined "All Circuits" or Session 2 view
// shouldn't force the header back to a single base league.
const fromLeague = byKey(Astro.url.searchParams.get('league') || '');
if (fromLeague) league = fromLeague;
// Display orientation: ?first=<slug> puts that player in the LEFT column. The
// pair slug itself stays alphabetical (a-vs-b and b-vs-a share one canonical
// URL), so this only swaps how the two are rendered.
if (Astro.url.searchParams.get('first') === parts[1]) { const t = a; a = b; b = t; }
const title = `${a.Player} vs ${b.Player} — Stat Comparison 2026 | Circuit Stats`;
const desc = `${a.Player} vs ${b.Player} head-to-head: PPG, rebounds, assists, shooting and totals compared. 2026 season.`;
---
<Layout
  title={title}
  trackTitle={`${a.Player} vs ${b.Player}`}
  description={desc}
  subLabel={league.subLabel}
  pillLabel={league.label}
  pageBase={league.urlBase}
  activeTab="compare"
  canonical={`${SITE}/compare/${slug}`}
>
  <Compare league={league} a={a} b={b} />
</Layout>
